rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isAuth() && getRole() == 'admin';
    }
    function isSeller() {
      return isAuth() && (getRole() == 'seller' || getRole() == 'admin');
    }
    function isMotoboy() {
      return isAuth() && (getRole() == 'motoboy' || getRole() == 'admin');
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{uid} {
      // Dono e admin sempre; vendedor também lê (PDV: busca de cliente p/ vincular
      // à venda presencial e atribuição de venda a um vendedor).
      allow read: if isOwner(uid) || isAdmin() || isSeller();
      allow create: if isOwner(uid);
      // Owner: atualiza o próprio perfil (menos o campo role). Inclui o débito
      // dos próprios pontos no resgate.
      // Admin: tudo.
      // A bonificação de indicação NÃO é mais creditada pelo cliente: ela acontece
      // no servidor (Admin SDK, via qualifyReferralForPaidOrder) somente após a 1ª
      // compra paga do indicado — por isso não há regra cliente que permita somar
      // pontos na conta de OUTRO usuário (fechando o vetor de abuso anterior).
      allow update: if (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Products ──────────────────────────────────────────────
    // Public catalog — anyone can read products.
    // Admins/sellers manage full CRUD.
    // Authenticated customers can only decrement stock (loyalty redemption).
    // ── Categorias de produto (gerenciadas pelo admin) ──────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() || isSeller();
    }

    // ── Áreas de entrega / frete por bairro (gerenciadas pelo admin) ──
    match /deliveryAreas/{areaId} {
      allow read: if true;
      allow write: if isAdmin() || isSeller();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin() || isSeller();
      allow update: if isAdmin()
                    || isSeller()
                    || (isAuth() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'variations', 'updatedAt']));
    }

    // ── Orders ────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuth() && (
        resource.data.customerId == request.auth.uid ||
        isAdmin() ||
        isSeller() ||
        (isMotoboy() && resource.data.motoboyId == request.auth.uid) ||
        // Pool de auto-atendimento: motoboys leem entregas ainda sem dono.
        (isMotoboy() && resource.data.motoboyId == null)
      );
      allow create: if isAuth() && request.resource.data.customerId == request.auth.uid;
      allow update: if isAdmin()
        || isSeller()
        || (isMotoboy() && resource.data.motoboyId == request.auth.uid)
        // Motoboy "pega" uma entrega sem dono, atribuindo-a a si mesmo. Só pode
        // mexer em motoboyId/motoboyName/updatedAt e quando ainda não há dono.
        || (isMotoboy()
            && resource.data.motoboyId == null
            && request.resource.data.motoboyId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['motoboyId', 'motoboyName', 'updatedAt']))
        || (isAuth() && resource.data.customerId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notes']))
        // Cliente respondendo "A compra foi efetuada?" (fluxo WhatsApp): pode
        // confirmar (awaitingConfirmation -> false) ou cancelar o próprio pedido.
        // Restrito aos campos do fluxo e ao status final received/cancelled, para
        // impedir escalonamento (ex.: marcar como entregue).
        || (isAuth() && resource.data.customerId == request.auth.uid
            && resource.data.status == 'received'
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['awaitingConfirmation', 'status', 'statusHistory',
                           'stockApplied', 'payment', 'paymentStatus', 'updatedAt'])
            && request.resource.data.status in ['received', 'cancelled']);
      allow delete: if isAdmin();
    }

    // ── Sales ─────────────────────────────────────────────────
    match /sales/{saleId} {
      allow read, write: if isAdmin() || isSeller();
    }

    // ── Loyalty Transactions ──────────────────────────────────
    // List: authenticated users (app always filters by userId in the query).
    // Get: owner or admin.
    // Create: any authenticated user (referrals and redemptions happen client-side).
    match /loyaltyTransactions/{txId} {
      allow list: if isAuth();
      allow get: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── Referral Codes ────────────────────────────────────────
    // Public lookup (code → uid) so a new user can resolve who referred them
    // without reading the private users collection. The mapping holds no PII.
    // Each user creates only their own mapping (uid must match); admins may seed.
    match /referralCodes/{code} {
      allow read: if isAuth();
      allow create, update: if isAdmin()
                            || (isAuth() && request.resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── Referrals (vínculo indicador↔indicado) ────────────────
    // Doc id = uid do indicado. Criado pelo próprio indicado no cadastro, sempre
    // como "pending" e sem pontos — a bonificação ao indicador só é liberada na
    // 1ª compra paga (Task 3.2), por caminho confiável (servidor/admin).
    // Leitura: o indicado, o indicador ou um admin.
    match /referrals/{referredUserId} {
      allow read: if isAuth() && (
        referredUserId == request.auth.uid ||
        resource.data.referrerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth()
                    && referredUserId == request.auth.uid
                    && request.resource.data.referredUserId == request.auth.uid
                    && request.resource.data.referrerId != request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.pointsAwarded == 0;
      // A promoção para "qualified" + crédito de pontos é feita pelo admin/servidor.
      allow update, delete: if isAdmin();
    }

    // ── Cupons de desconto (Task 3.3) ─────────────────────────
    // Leitura por usuários logados (validação do código no checkout).
    // Gerenciamento (criar/editar/excluir) restrito a admin/vendedor.
    match /coupons/{code} {
      allow read: if isAuth();
      allow write: if isAdmin() || isSeller();
    }

    // Registros de uso do cupom: o cliente cria o próprio uso ao fechar o pedido;
    // leitura liberada a logados (contagem por CPF no checkout). Edição/remoção admin.
    match /couponRedemptions/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Lounge Bookings ───────────────────────────────────────
    // Criação pública (formulário sem login), mas valida os campos obrigatórios
    // e força status "pending" para impedir reservas-lixo ou já "aprovadas".
    match /lounge_bookings/{bookingId} {
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.name is string && request.resource.data.name.size() > 0
                    && request.resource.data.whatsapp is string && request.resource.data.whatsapp.size() > 0
                    && request.resource.data.date is string
                    && request.resource.data.time is string;
      allow read, update, delete: if isAdmin();
    }

    // ── Lounge Slots (trava pública de horário, sem PII) ──────
    // Guarda apenas { date, time } para impedir conflito de horário. Leitura
    // pública permite ao formulário desabilitar horários ocupados. Qualquer um
    // pode CRIAR um slot livre (a transação garante unicidade), mas só o admin
    // pode sobrescrever/remover — o que impede roubar/alterar um slot existente.
    // A criação só aceita exatamente { date, time, createdAt } (sem lixo extra).
    match /lounge_slots/{slotId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['date', 'time', 'createdAt'])
                    && request.resource.data.date is string
                    && request.resource.data.time is string;
      allow update, delete: if isAdmin();
    }

    // ── Banners / CMS ─────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Site Settings ─────────────────────────────────────────
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Stock Movements ───────────────────────────────────────
    match /stockMovements/{movId} {
      allow read, write: if isAdmin() || isSeller();
    }

    // ── Reviews (avaliações de pedidos) ───────────────────────
    // List: autenticados (o app filtra por customerId). Get: dono ou admin.
    // Create: o próprio cliente. Update/delete: só admin.
    match /reviews/{id} {
      allow list:   if isAuth();
      allow get:    if isAuth() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Commissions ───────────────────────────────────────────
    match /commissions/{commId} {
      allow read: if isAdmin() || (isAuth() && resource.data.sellerId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── Reports (problemas reportados por usuários) ───────────
    // Qualquer um pode criar um reporte (inclusive visitante não logado), desde
    // que tenha uma mensagem válida e status "open". Só o admin lê/resolve/exclui.
    match /reports/{reportId} {
      allow create: if request.resource.data.status == 'open'
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 2000
                    && request.resource.data.page is string;
      allow read, update, delete: if isAdmin();
    }
  }
}
